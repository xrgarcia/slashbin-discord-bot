# Required: Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your-discord-bot-token-here

# Recommended: Point at your project repo (where CLAUDE.md, .mcp.json, and skills live)
# This is how the bot gets its personality, context, and capabilities
CLAUDE_CWD=/path/to/your/project-repo

# Optional: Lock bot to specific Discord user IDs (comma-separated)
# Find your user ID: Discord Settings > Advanced > Developer Mode, then right-click your name
ALLOWED_USERS=

# Optional: Channel IDs where the bot responds to ALL messages (no @mention needed)
# Comma-separated. Right-click channel > Copy Channel ID (requires Developer Mode in Discord settings)
MONITOR_CHANNELS=

# Optional: Allow specific bot IDs to interact with this bot (comma-separated)
# By default, all bot messages are ignored. Add bot user IDs here to allow bot-to-bot communication.
# Both bots must whitelist each other — see README for details.
ALLOWED_BOTS=

# Optional: Max back-and-forth exchanges with another bot before stopping (default: 2)
# Prevents infinite bot-to-bot loops. Resets when a human sends a message.
# MAX_BOT_EXCHANGES=2

# Optional: Override the system prompt appended to every Claude session
# BOT_SYSTEM_PROMPT=You are running inside a Discord bot. Keep responses concise.

# Optional: Path to claude binary (defaults to "claude")
# CLAUDE_BIN=claude

# Optional: Session timeout in ms (default: 1800000 = 30 minutes)
# SESSION_TIMEOUT_MS=1800000

# Optional: Max time per Claude session in ms (default: 3600000 = 1 hour)
# CLAUDE_TIMEOUT_MS=3600000

# Optional: Log level (debug, info, warn, error)
# LOG_LEVEL=info

# Optional: Set to "production" to disable pretty logging
# NODE_ENV=production
